#!/bin/bash
# .githooks/commit-msg
commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")
# Skip merge commits
if echo "$commit_msg" | grep -q "^Merge branch"; then
    exit 0
fi
# Enforce conventional commits with issue reference
# Format: type(scope): description #issue
# Example: feat(plotting): add violin plot with quartile markers
pattern="^(feat|fix|docs|style|refactor|test|chore|perf|data)(\(.+\))?: .{10,}( #[0-9]+)?$"
if ! echo "$commit_msg" | grep -qE "$pattern"; then
    echo "ERROR: Commit message must follow conventional commits format"
    echo ""
    echo "Format: type(scope): description"
    echo ""
    echo "Types for your work:"
    echo "  feat:     New plotting function or feature"
    echo "  fix:      Bug fix"
    echo "  docs:     Documentation (docstrings, README, guides)"
    echo "  refactor: Code restructuring"
    echo "  test:     Adding or updating tests"
    echo "  perf:     Performance improvements"
    echo "  data:     Example datasets or demo updates"
    echo "  chore:    Maintenance (dependencies, configs)"
    echo ""
    echo "Examples:"
    echo "  feat(plotting): add violin plot with quartile markers"
    echo "  fix(stats): correct percentile calculation #12"
    echo "  docs(api): update docstring examples for scatter"
    echo "  refactor(core): simplify colour palette handling"
    echo "  perf(rendering): optimise large dataset display"
    echo ""
    exit 1
fi
# Check message length (first line should be <72 chars)
first_line=$(echo "$commit_msg" | head -n1)
if [ ${#first_line} -gt 72 ]; then
    echo "WARNING: First line is ${#first_line} chars (recommend <72)"
fi
exit 0
